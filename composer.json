{
  "name": "sns/design-laboratori-wordpress-theme",
  "type": "project",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.1",
    "phpstan/phpstan": "1.12"
  },
  "scripts": {
    "lint:php": "phpcs --standard=phpcs.xml.dist",
    "lint:php:fix": "phpcbf --standard=phpcs.xml.dist",
    "lint:phpstan": "phpstan analyse --configuration=phpstan.neon --no-progress --memory-limit=512M"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
