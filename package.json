{
  "name": "design-laboratori-wordpress-theme",
  "version": "REL-3",
  "description": "Tema Wordpress dei Laboratori Italiani",
  "main": "index.js",
  "scripts": {
    "build": "npm run minify:css && npm run minify:js",
    "lint": "npm run lint:php",
    "lint:php": "composer lint:php -- .",
    "lint:php:file": "composer lint:php --",
    "lint:php:fix": "composer lint:php:fix -- .",
    "lint:php:fix:file": "composer lint:php:fix --",
    "version": "node DEV/npm_scripts/config-sync && git add style.css && git add README.md",
    "postversion": "echo \"You can now publish your tag with 'git push --follow-tags'\"",
    "minify:css": "node DEV/npm_scripts/minify-css.js",
    "minify:js": "node DEV/npm_scripts/minify-js.js",
    "create_layout": "npx sass --load-path=node_modules assets/scss/bootstrap-italia-custom.scss:assets/css/compiled/bootstrap-italia-custom.min.css --style=compressed",
    "update_layout_win": "npm run create_layout && xcopy .\\assets\\css\\compiled\\bootstrap-italia-custom.min.* .\\assets\\css\\ /Y",
    "update_layout_linux": "npm run create_layout && cp -f ./assets/css/compiled/bootstrap-italia-custom.min.* ./assets/css/",
    "status:scan": "node tests/e2e/status-report/scan.js",
    "status:scan:install-browser": "npx playwright install chromium",
    "status:compare": "node tests/e2e/status-report/compare.js",
    "quality:scan": "node tests/e2e/quality-report/scan.js",
    "quality:scan:gate": "node tests/e2e/quality-report/scan.js --gate",
    "quality:compare": "node tests/e2e/quality-report/compare.js",
    "ux:scan": "node tests/e2e/ux-report/scan.js",
    "ux:scan:gate": "node tests/e2e/ux-report/scan.js --gate",
    "ux:compare": "node tests/e2e/ux-report/compare.js",
    "html:scan": "node tests/e2e/html-report/scan.js",
    "html:scan:gate": "node tests/e2e/html-report/scan.js --gate",
    "html:compare": "node tests/e2e/html-report/compare.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScuolaNormaleSuperiore/design-laboratori-wordpress-theme.git"
  },
  "author": "Presidenza del Consiglio dei Ministri",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/ScuolaNormaleSuperiore/design-laboratori-wordpress-theme/issues"
  },
  "homepage": "https://github.com/ScuolaNormaleSuperiore/design-laboratori-wordpress-theme#readme",
  "dependencies": {
    "bootstrap-italia": "^2.18.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "clean-css-cli": "^5.6.1",
    "playwright": "^1.50.0",
    "replace-in-file": "^6.3.5",
    "sass": "^1.81.0",
    "uglify-js": "^3.17.4",
    "vnu-jar": "^26.3.17"
  }
}
